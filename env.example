# Required
SP_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CERT_THUMBPRINT=YOUR_CERT_THUMBPRINT_NO_SPACES
SP_PRIVATE_KEY_PATH=/absolute/path/to/private_key.pem
SP_SITE_URL=https://edison.sharepoint.com/sites/ext_teams_leadingsoft_pict-CRJ
SP_ROOT_FOLDER_SERVER_RELATIVE_URL=/sites/ext_teams_leadingsoft_pict-CRJ/Shared Documents

# Optional
SP_DAYS_TO_KEEP=30
SP_DRY_RUN=true
SP_TIMEOUT_SECONDS=60
SP_SLEEP_BETWEEN_REQUESTS=0.0
SP_SKIP_FOLDER_NAMES=Forms
SP_API_KEY=your-strong-api-key
SP_API_HOST=0.0.0.0
SP_API_PORT=8000
